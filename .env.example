# LEGISTAR_API_KEY=not_required  # Legistar data is publicly accessible

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/open-navigator.log

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4


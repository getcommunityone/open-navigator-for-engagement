PROPUBLICA_CAMPAIGN_FINANCE_API_KEY=your_propublica_campaign_finance_api_key  # Campaign Finance API: FEC filings, donations
PROPUBLICA_VITAL_SIGNS_API_KEY=your_propublica_vital_signs_api_key  # Vital Signs API: Healthcare provider data


# 🐘 FAST STATS DATABASE (POSTGRES)
# ======================================================================

# For development: Use local PostgreSQL or Neon dev database
# 1. Install PostgreSQL: https://www.postgresql.org/download/
# 2. Create database: createdb open_navigator_stats
# 3. Run migration: python scripts/deployment/neon/migrate.py
NEON_DATABASE_URL_DEV=postgresql://postgres:postgres@localhost:5432/open_navigator_stats

# For production (HuggingFace): Use Neon Postgres
# Get from: https://neon.tech → Your Project → Connection Details
# Free tier: 500MB storage, perfect for summary/reference data
# Note: NEON_DATABASE_URL_DEV takes priority if both are set
NEON_DATABASE_URL=postgresql://user:password@your-project.neon.tech/dbname?sslmode=require

# ======================================================================
# 🔑 API KEYS
# ======================================================================

# OpenAI API Key (for GPT models)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (for Claude models)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Logo.dev API Key (for organization logos)
# Sign up at: https://www.logo.dev/
# Free tier: 1,000 requests/month
LOGODEV_API_KEY=your_logodev_api_key_here

# ======================================================================
# 🔐 AUTHENTICATION & DATABASE
# ======================================================================

# Main Application Database (User accounts, OAuth tokens, settings)
# 
# OPTION 1: Neon Serverless PostgreSQL (FREE TIER - RECOMMENDED for production)
# Sign up at: https://neon.tech
# 1. Create a new project
# 2. Copy the connection string from the dashboard
# 3. Paste it below (format: postgresql://user:password@host/dbname?sslmode=require)
# DATABASE_URL=postgresql://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# OPTION 2: Local PostgreSQL (for development)
# Install PostgreSQL: https://www.postgresql.org/download/
# Then create database: createdb communityone
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/communityone

# OPTION 3: Local SQLite (simplest for development, no PostgreSQL needed)
# Uncomment to use SQLite instead of PostgreSQL
# DATABASE_URL=sqlite:///./data/users.db

# Open States Legislative Database (for bill tracking, legislators, votes)
# 
# OPTION 1: Local PostgreSQL (RECOMMENDED - use downloaded dump)
# 1. Download dump: python scripts/bulk_legislative_download.py --postgres --month 2026-04
# 2. Create database: createdb openstates
# 3. Restore dump: pg_restore --dbname=openstates --no-owner data/cache/legislation_bulk/postgres/2026-04-public.pgdump
OPENSTATES_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/openstates

# OPTION 2: Docker PostgreSQL (RECOMMENDED for clean isolation)
# docker run -d --name openstates-db -e POSTGRES_PASSWORD=openstates -e POSTGRES_DB=openstates -p 5433:5432 postgres:15
# Then restore: docker exec -i openstates-db pg_restore --dbname=openstates --username=postgres --no-owner /path/to/dump
# OPENSTATES_DATABASE_URL=postgresql://postgres:openstates@localhost:5433/openstates

# OPTION 3: Neon (PAID - for production hosting ~$69/month for 20GB)
# OPENSTATES_DATABASE_URL=postgresql://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/openstates?sslmode=require

# JWT Secret Key (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=your_random_secret_key_here_min_32_chars

# Frontend URL (for OAuth redirects)
# Frontend URL - where to redirect after OAuth
# For HuggingFace (same domain deployment): Leave blank or set to https://www.communityone.com
# For local dev (separate servers): http://localhost:5173
FRONTEND_URL=http://localhost:5173

# OAuth Providers - Get credentials from each provider's developer console
# See setup guide: website/docs/deployment/authentication-setup.md

# HuggingFace OAuth (https://huggingface.co/settings/applications)
HUGGINGFACE_CLIENT_ID=your_hf_client_id
HUGGINGFACE_CLIENT_SECRET=your_hf_client_secret

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook OAuth (https://developers.facebook.com/apps)
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
# GitHub API Token for creating issues (https://github.com/settings/tokens)
# Required for contact form functionality
# Permissions needed: repo (for creating issues)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=getcommunityone/open-navigator
# ======================================================================
# � HUGGINGFACE DEPLOYMENT
# ======================================================================

# HuggingFace Username (REQUIRED for deployment)
# Used by ./deploy-huggingface.sh to deploy to HuggingFace Spaces
# Set this to your HuggingFace username (e.g., CommunityOne)
HF_USERNAME=your_hf_username

# HuggingFace API Token (REQUIRED for deployment)
# Get from: https://huggingface.co/settings/tokens
# Used for authentication when deploying via ./deploy-huggingface.sh
# Also used for OAuth login (see HUGGINGFACE_CLIENT_ID above)
HUGGINGFACE_TOKEN=your_huggingface_token_here

# Optional: Organization name for dataset sharing
HF_ORGANIZATION=CommunityOne
HF_DATASET_PREFIX=one

# ======================================================================
# 📊 DATA SOURCE API KEYS
# ======================================================================
DATAVERSE_API_KEY=your_dataverse_api_key  # Optional: Get at https://dataverse.harvard.edu/loginpage.xhtml
OPENSTATES_API_KEY=your_openstates_api_key  # Free: Sign up at https://openstates.org/accounts/signup/
GOOGLE_CIVIC_API_KEY=your_google_civic_api_key  # Free: Get at https://console.cloud.google.com/ (25k requests/day)

# ProPublica Data APIs (Free with registration - 5,000 requests/day)
# Sign up at: https://www.propublica.org/datastore/apis
PROPUBLICA_CONGRESS_API_KEY=your_propublica_congress_api_key  # Congress API: Roll-call votes, bills, member data
PROPUBLICA_CAMPAIGN_FINANCE_API_KEY=your_propublica_campaign_finance_api_key  # Campaign Finance API: FEC filings, donations
PROPUBLICA_VITAL_SIGNS_API_KEY=your_propublica_vital_signs_api_key  # Vital Signs API: Healthcare provider data

# PAID SERVICES (Optional - for reference only)
# BALLOTPEDIA_API_KEY=your_ballotpedia_api_key  # PAID: Contact https://ballotpedia.org/API_documentation
# CICERO_API_KEY=your_cicero_api_key  # PAID: Contact https://cicerodata.com (enterprise pricing)

# HuggingFace Configuration
HF_USERNAME=your_hf_username  # Your Hugging Face username (for Space deployment)
HF_ORGANIZATION=CommunityOne  # Optional: for dataset sharing
HF_DATASET_PREFIX=one  # Prefix for dataset names

# Databricks Configuration
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=your_databricks_token_here
DATABRICKS_WAREHOUSE_ID=your_warehouse_id_here

# Delta Lake Configuration
DELTA_LAKE_PATH=dbfs:/open-navigator
CATALOG_NAME=main
SCHEMA_NAME=agents

# MLflow Configuration (for Databricks Agent Bricks)
MLFLOW_TRACKING_URI=databricks
MLFLOW_EXPERIMENT_NAME=/Users/shared/open-navigator-agents
MLFLOW_MODEL_NAME_PREFIX=open_navigator

# Agent LLM Configuration
CLASSIFIER_MODEL=gpt-4-turbo-preview
SENTIMENT_MODEL_LLM=gpt-3.5-turbo
ADVOCACY_MODEL=gpt-4-turbo-preview

# Jurisdiction Discovery Configuration
# Note: No external search APIs needed - uses pattern matching + GSA .gov registry

# Agent Configuration
MAX_CONCURRENT_AGENTS=5
SCRAPER_TIMEOUT=30
CLASSIFIER_BATCH_SIZE=50
SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english

# Public Data Sources (No API keys needed - all FREE public data)
# MUNICODE_API_KEY=not_required  # Municode data is publicly accessible
# LEGISTAR_API_KEY=not_required  # Legistar data is publicly accessible

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/open-navigator.log

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ======================================================================
# 📊 ANALYTICS
# ======================================================================

# Google Analytics 4 Measurement ID (use same ID for docs and frontend)
# Get from: https://analytics.google.com (GA4 property)
# Format: G-XXXXXXXXXX
GOOGLE_ANALYTICS_ID=G-5EQV815915

# Vector Database
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=policy_minutes

# Email Configuration (for advocacy drafts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_app_password
VITE_API_URL=api
# ======================================================================
# 🐘 NEON DATABASE (POSTGRES)
# ======================================================================

# Neon Postgres Database URL (for production deployment)
# Get from: https://neon.tech → Your Project → Connection Details
# Free tier: 500MB storage, perfect for summary/reference data
NEON_DATABASE_URL=postgresql://user:password@your-project.neon.tech/dbname?sslmode=require

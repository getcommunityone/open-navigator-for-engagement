# API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
HUGGINGFACE_TOKEN=your_huggingface_token_here

# ======================================================================
# 🔐 AUTHENTICATION & DATABASE
# ======================================================================

# Neon Serverless PostgreSQL Database (FREE TIER - RECOMMENDED)
# Sign up at: https://neon.tech
# 1. Create a new project
# 2. Copy the connection string from the dashboard
# 3. Paste it below (format: postgresql://user:password@host/dbname?sslmode=require)
DATABASE_URL=postgresql://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# JWT Secret Key (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=your_random_secret_key_here_min_32_chars

# Frontend URL (for OAuth redirects)
# Frontend URL - where to redirect after OAuth
# For HuggingFace (same domain deployment): Leave blank or set to https://www.communityone.com
# For local dev (separate servers): http://localhost:5173
FRONTEND_URL=http://localhost:5173

# OAuth Providers - Get credentials from each provider's developer console
# See setup guide: website/docs/deployment/authentication-setup.md

# HuggingFace OAuth (https://huggingface.co/settings/applications)
HUGGINGFACE_CLIENT_ID=your_hf_client_id
HUGGINGFACE_CLIENT_SECRET=your_hf_client_secret

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook OAuth (https://developers.facebook.com/apps)
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ======================================================================
# 🗄️  DATA SOURCE API KEYS
# ======================================================================
DATAVERSE_API_KEY=your_dataverse_api_key  # Optional: Get at https://dataverse.harvard.edu/loginpage.xhtml
OPENSTATES_API_KEY=your_openstates_api_key  # Free: Sign up at https://openstates.org/accounts/signup/

# HuggingFace Configuration
HF_USERNAME=your_hf_username  # Your Hugging Face username (for Space deployment)
HF_ORGANIZATION=CommunityOne  # Optional: for dataset sharing
HF_DATASET_PREFIX=one  # Prefix for dataset names

# Databricks Configuration
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=your_databricks_token_here
DATABRICKS_WAREHOUSE_ID=your_warehouse_id_here

# Delta Lake Configuration
DELTA_LAKE_PATH=dbfs:/oral-health-policy-pulse
CATALOG_NAME=main
SCHEMA_NAME=agents

# MLflow Configuration (for Databricks Agent Bricks)
MLFLOW_TRACKING_URI=databricks
MLFLOW_EXPERIMENT_NAME=/Users/shared/oral-health-agents
MLFLOW_MODEL_NAME_PREFIX=oral_health

# Agent LLM Configuration
CLASSIFIER_MODEL=gpt-4-turbo-preview
SENTIMENT_MODEL_LLM=gpt-3.5-turbo
ADVOCACY_MODEL=gpt-4-turbo-preview

# Jurisdiction Discovery Configuration
# Note: No external search APIs needed - uses pattern matching + GSA .gov registry

# Agent Configuration
MAX_CONCURRENT_AGENTS=5
SCRAPER_TIMEOUT=30
CLASSIFIER_BATCH_SIZE=50
SENTIMENT_MODEL=distilbert-base-uncased-finetuned-sst-2-english

# Public Data Sources (No API keys needed - all FREE public data)
# MUNICODE_API_KEY=not_required  # Municode data is publicly accessible
# LEGISTAR_API_KEY=not_required  # Legistar data is publicly accessible

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/oral-health-policy-pulse.log

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Vector Database
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=policy_minutes

# Email Configuration (for advocacy drafts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_app_password

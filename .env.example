# ======================================================================
# 🔑 API KEYS
# ======================================================================

# OpenAI API Key (for GPT models)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (for Claude models)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Logo.dev API Key (for organization logos)
# Sign up at: https://www.logo.dev/
# Free tier: 1,000 requests/month
LOGODEV_API_KEY=your_logodev_api_key_here

# ======================================================================
# 🔐 AUTHENTICATION & DATABASE
# ======================================================================

# PostgreSQL Password (for local development)
# Used by local PostgreSQL databases (openstates, open_navigator)
# Note: open_navigator database has bronze/staging/intermediate/public schemas
POSTGRES_PASSWORD=password

# Main Application Database (User accounts, OAuth tokens, settings)
# 
# OPTION 1: Neon Serverless PostgreSQL (FREE TIER - RECOMMENDED for production)
# Sign up at: https://neon.tech
# 1. Create a new project
# 2. Copy the connection string from the dashboard
# 3. Paste it below (format: postgresql://user:password@host/dbname?sslmode=require)
# DATABASE_URL=postgresql://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# OPTION 2: Local PostgreSQL (for development)
# Install PostgreSQL: https://www.postgresql.org/download/
# Then create database: createdb communityone
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/communityone

# OPTION 3: Local SQLite (simplest for development, no PostgreSQL needed)
# Uncomment to use SQLite instead of PostgreSQL
# DATABASE_URL=sqlite:///./data/users.db

# Open States Legislative Database (for bill tracking, legislators, votes)
# 
# OPTION 1: Local PostgreSQL (RECOMMENDED - use downloaded dump)
# 1. Download dump: python scripts/bulk_legislative_download.py --postgres --month 2026-04
# 2. Create database: createdb openstates
# 3. Restore dump: pg_restore --dbname=openstates --no-owner data/cache/legislation_bulk/postgres/2026-04-public.pgdump
OPENSTATES_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/openstates

# OPTION 2: Docker PostgreSQL (RECOMMENDED for clean isolation)
# docker run -d --name openstates-db -e POSTGRES_PASSWORD=openstates -e POSTGRES_DB=openstates -p 5433:5432 postgres:15
# Then restore: docker exec -i openstates-db pg_restore --dbname=openstates --username=postgres --no-owner /path/to/dump
# OPENSTATES_DATABASE_URL=postgresql://postgres:openstates@localhost:5433/openstates

# OPTION 3: Neon (PAID - for production hosting ~$69/month for 20GB)
# OPENSTATES_DATABASE_URL=postgresql://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/openstates?sslmode=require

# JWT Secret Key (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=your_random_secret_key_here_min_32_chars

# Frontend URL (for OAuth redirects)
# Frontend URL - where to redirect after OAuth
# For HuggingFace (same domain deployment): Leave blank or set to https://www.communityone.com
# For local dev (separate servers): http://localhost:5173
FRONTEND_URL=http://localhost:5173

# OAuth Providers - Get credentials from each provider's developer console
# See setup guide: website/docs/deployment/authentication-setup.md

# HuggingFace OAuth (https://huggingface.co/settings/applications)
# Required redirect URIs:
#   - Development: http://localhost:8000/api/auth/callback/huggingface
#   - Production: https://www.communityone.com/api/auth/callback/huggingface
HUGGINGFACE_CLIENT_ID=your_hf_client_id
HUGGINGFACE_CLIENT_SECRET=your_hf_client_secret

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Required redirect URIs:
#   - Development: http://localhost:8000/api/auth/callback/google
#   - Production: https://www.communityone.com/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
# Required redirect URIs:
#   - Development: http://localhost:8000/api/auth/callback/facebook
#   - Production: https://www.communityone.com/api/auth/callback/facebook
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Facebook OAuth (https://developers.facebook.com/apps)
FACEBOOK_APP_ID=your_facebook_app_id
# Required redirect URIs:
#   - Development: http://localhost:8000/api/auth/callback/github
#   - Production: https://www.communityone.com/api/auth/callback/github
FACEBOOK_APP_SECRET=your_facebook_app_secret

# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
# GitHub API Token for creating issues (https://github.com/settings/tokens)
# Required for contact form functionality
# Permissions needed: repo (for creating issues)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=getcommunityone/open-navigator
# ======================================================================
# � HUGGINGFACE DEPLOYMENT
# ======================================================================

# HuggingFace Username (REQUIRED for deployment)
# Used by ./deploy-huggingface.sh to deploy to HuggingFace Spaces
# Set this to your HuggingFace username (e.g., CommunityOne)
HF_USERNAME=your_hf_username

# HuggingFace API Token (REQUIRED for deployment)
# Get from: https://huggingface.co/settings/tokens
# Used for authentication when deploying via ./deploy-huggingface.sh
# Also used for OAuth login (see HUGGINGFACE_CLIENT_ID above)
HUGGINGFACE_TOKEN=your_huggingface_token_here

# Optional: Organization name for dataset sharing
HF_ORGANIZATION=CommunityOne
HF_DATASET_PREFIX=one

# ======================================================================
# 📊 DATA SOURCE API KEYS
# ======================================================================
CENSUS_API_KEY=your_census_api_key  # Free: Sign up at https://api.census.gov/data/key_signup.html (5,000 requests/day)
DATAVERSE_API_KEY=your_dataverse_api_key  # Optional: Get at https://dataverse.harvard.edu/loginpage.xhtml
OPENSTATES_API_KEY=your_openstates_api_key  # Free: Sign up at https://openstates.org/accounts/signup/
GOOGLE_CIVIC_API_KEY=your_google_civic_api_key  # Free: Get at https://console.cloud.google.com/ (25k requests/day)

# Wikidata Query Service — reduce overload (504 / Blazegraph timeouts, 429). Wikimedia throttles WDQS heavily by IP + User-Agent (~60s server query/min + burst / error-rate caps → 429/502 cascades).
# May 2025 graph split: https://query.wikidata.org/ = **main** graph (places, gov, orgs). Scholarly-only data: https://query-scholarly.wikidata.org/ . Legacy full graph (slow, transient): query-legacy-full.wikidata.org — see Wikidata:SPARQL_query_service/WDQS_graph_split
# WIKIDATA_SPARQL_GRAPH=main         # main (default jurisdictions) | scholarly | legacy_full — or set WIKIDATA_SPARQL_ENDPOINT to a full …/sparql URL
# WIKIDATA_SPARQL_ENDPOINT=           # overrides WIKIDATA_SPARQL_GRAPH when non-empty (e.g. https://query-scholarly.wikidata.org/sparql)
# WIKIDATA_SPARQL_MAX_GET_QUERY_CHARS=6000    # queries longer than this → application/x-www-form-urlencoded POST (avoids URL-length limits)
# WIKIDATA_SPARQL_TIMEOUT_SECONDS=120
# WIKIDATA_WIKIBASE_API_TIMEOUT_SECONDS=75   # wbgetentities / wbsearchentities only (default min(SPARQL,75s); shorter avoids long hangs if SOCKS/WARP is down)
# WIKIDATA_WDQS_QUOTA_WINDOW_SECONDS=60       # sliding window used for pacing below
# WIKIDATA_WDQS_BUDGET_SECONDS_PER_WINDOW=50 # stay under Wikimedia rolling query-time cap (~60s/min + burst proxy)
# WIKIDATA_WDQS_BUDGET_BURST_SECONDS=115
# WIKIDATA_WDQS_ERROR_WINDOW_SECONDS=60
# WIKIDATA_WDQS_ERROR_PAUSE_THRESHOLD=24    # if this many WDQS failures in the window (~30/min hard cap); triggers cooldown
# WIKIDATA_WDQS_ERROR_STORM_PAUSE_SECONDS=90
#
# WIKIDATA_INCREMENTAL_MERGE=1     # default ON: keep existing QIDs in bronze *_wikidata; seed merges new Census rows; WDQS only for NULL wikidata_id. Set 0 to DELETE+re-seed each run (full refresh; slow).
# WIKIDATA_PRIORITY_STATES_SKIP_COMPLETE=1  # default ON (--priority-states only): skip USPS already fully enriched for the requested --types (no NULL wikidata_id). Set 0 to always attempt all six priority states.
#
# "Happy path" (avoid 429 / stay within WDQS budget — backfill stragglers later):
#   export WIKIDATA_HAPPY_PATH=1
#   … or:  .venv/bin/python scripts/datasources/wikidata/load_jurisdictions_wikidata.py --happy-path --priority-states --types county
#   … or:  ./scripts/datasources/wikidata/run_wikidata_happy_path.sh --priority-states --types county,city
# Fills **only unset** keys with: Retry-After cap 120s, throttle 12s, task sleep 8s, incremental merge,
# priority skip-complete, county-gap off, muni/school bulk **without** FILTER supplement, **no** county
# entity-search fallback, chunk sleep 3s. Override any key in .env as usual.
# Backfill: unset WIKIDATA_HAPPY_PATH and set e.g. WIKIDATA_MUNICIPALITY_BULK_SUPPLEMENT_SPARQL=1,
# WIKIDATA_COUNTY_BULK_FALLBACK_ENTITY_SEARCH=1, or WIKIDATA_LOAD_RETRY_COUNTY_GAPS=1 for gap states.
# WIKIDATA_CACHE_DIR=data/cache/wikidata   # SPARQL response JSON cache (not Postgres — see wikidata_integration.py); hybrid mode also writes geography_qid_mapping_v1.json here
# WIKIDATA_CACHE_TTL_SECONDS=604800        # 7d default; extend to reuse file cache longer between runs
#
# Hybrid enrichment (recommended when WDQS times out): narrow WDQS to id→item (P774/P590/P882/P6545…), hydrate claims via Wikibase wbgetentities
# WIKIDATA_HYBRID_ENRICH=1
# County id→Q: bulk_state = **one** WDQS query per state (P131=state + types), match FIPS in memory (default). entity_search = slow per-county API. sparql = FILTER IN batches.
# WIKIDATA_HYBRID_COUNTY_MAP_MODE=bulk_state
# WIKIDATA_COUNTY_BULK_STATE_LIMIT=600       # max rows from bulk query (max ~Texas counties + headroom)
# WIKIDATA_COUNTY_BULK_FALLBACK_ENTITY_SEARCH=1   # if bulk WDQS misses a GEOID, try entity-search for that row only
# Municipality + school (hybrid id→Q): bulk_state = **one** WDQS query per state (P131+ / types or Q1455778), match literals in memory; sparql = FILTER batches per chunk only.
# WIKIDATA_HYBRID_MUNICIPALITY_MAP_MODE=bulk_state
# WIKIDATA_MUNICIPALITY_BULK_STATE_LIMIT=8000
# WIKIDATA_MUNICIPALITY_BULK_SUPPLEMENT_SPARQL=1   # after bulk P131+ match: 0 = skip extra FILTER IN WDQS for misses (less load; stricter bulk-only)
# WIKIDATA_MUNICIPALITY_POST_BULK_WDQS_GAP_SECONDS=10   # pause after bulk WDQS before first FILTER supplement (429 mitigation when supplement=1)
# WIKIDATA_MUNICIPALITY_FILTER_WDQS_GAP_SECONDS=6     # pause before each municipality FILTER IN WDQS call
# WIKIDATA_HYBRID_SCHOOL_MAP_MODE=bulk_state
# WIKIDATA_SCHOOL_BULK_STATE_LIMIT=2500
# WIKIDATA_SCHOOL_POST_BULK_WDQS_GAP_SECONDS=10
# WIKIDATA_SCHOOL_FILTER_WDQS_GAP_SECONDS=6
# US state row: optional batched wbgetentities for all STATE_MAP Q-ids on first state task (opt-in; helps full-US sweeps).
# WIKIDATA_STATE_BULK_WBGETENTITIES=0
# WIKIDATA_QID_CACHE_WARM_DB=1       # merge existing Postgres *_wikidata QIDs into <WIKIDATA_CACHE_DIR>/geography_qid_mapping_v1.json before each state's hybrid run (set 0 to use only SPARQL + on-disk JSON)
# WIKIDATA_ENRICH_USE_PYWIKIBOT=1     # optional: ItemPage hydration via pywikibot instead of REST (needs pip install pywikibot)
# WIKIDATA_STATE_LEGACY_SPARQL=1      # use WDQS + label service for US state row; default is Wikibase wbgetentities / same JSON as Special:EntityData/{Q}.json
# WIKIDATA_THROTTLE_SECONDS=6      # minimum seconds between WDQS requests (per process lock)
# WIKIDATA_RETRY_AFTER_MAX_SECONDS=120   # cap 429 Retry-After (≤0 = uncapped, WDQS can send ~1000s — avoid for bulk)
# # Optional Docker WARP / SOCKS egress (routes WDQS + w/api.php only; not generic HTTP_PROXY):
# # WIKIDATA_HTTPS_PROXY=socks5://127.0.0.1:1080
# WIKIDATA_CONNECT_RETRY_BASE_SECONDS=10   # exponential backoff base for TCP connect failures to WDQS
# WIKIDATA_CONNECT_RETRY_MAX_SECONDS=300    # max seconds per connect-retry wait
# WIKIDATA_SPARQL_MAX_ATTEMPTS=10          # retries per query
# WIKIDATA_TASK_SLEEP_SECONDS=2   # pause between jurisdiction tasks in load_jurisdictions_wikidata.py
#
# County SPARQL default: FIPS-batched queries from bronze GEIDs (skips expensive P131+ across the state).
# WIKIDATA_COUNTY_LEGACY_STATE_QUERY=0   # force old P131+ one-query-per-state behavior
# WIKIDATA_COUNTY_FIPS_BATCH=1          # unset or 1 = batches; 0 with no legacy flag = fall back to legacy
# WIKIDATA_COUNTY_CHUNK_SIZE=35         # GEOIDs per WDQS chunk (5–120)
# WIKIDATA_COUNTY_CHUNK_SLEEP_SECONDS=1 # pause between county chunks (same process; eases 429/timeout)
#
# Municipality + schooldistrict SPARQL (same pacing env as counties)
# WIKIDATA_CITY_IDENTIFIER_BATCH=1          # bronze geoid/GNIS → P774+P590 FILTER batches (skip P131+)
# WIKIDATA_CITY_LEGACY_STATE_QUERY=0       # force old single-state P131+ crawl + LIMIT 2000
# WIKIDATA_CITY_CHUNK_SIZE=25               # GEOID rows per batch (5–150)
#
# WIKIDATA_SCHOOL_IDENTIFIER_BATCH=1       # bronze NCES/GEOID chunks (no P131+, no superintendent sub-query)
# WIKIDATA_SCHOOL_LEGACY_STATE_QUERY=1      # superintendent + P131+ (slow/timeouts likely)
# WIKIDATA_SCHOOL_CHUNK_SIZE=35             # district GEOIDs per batch (5–200)
#
# Jurisdictions loader (load_jurisdictions_wikidata.py) — run ./scripts/datasources/wikidata/run_load_jurisdictions_wikidata.sh
# WIKIDATA_LOAD_RETRY_COUNTY_GAPS=1      # Postgres: rerun county task only where n_wikidata_rows < n_base OR enriched < n_base (clears checkpoint per USPS)
# WIKIDATA_LOAD_ALL_US_STATES=0           # full US sweep (ignored when RETRY_COUNTY_GAPS=1)
# WIKIDATA_LOAD_PRIORITY_STATES=1        # CLI --priority-states default on (six states: AL,GA,IN,MA,WA,WI)
# WIKIDATA_LOAD_TYPES=city,county,state,school_district   # loader default matches this unless you shrink it

# Optional: force all Python loaders to a single Postgres URL (overrides NEON_* when set)
# OPEN_NAVIGATOR_DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require
# WIKIDATA_LOAD_CHECKPOINT_FILE=    # default: <WIKIDATA_CACHE_DIR>/wikidata_jurisdictions_checkpoint.json
# WIKIDATA_LOAD_FORCE=0                  # set 1 to ignore checkpoint (--no-force on CLI to override env)
# WIKIDATA_LOAD_STATES=AL,TX,OH           # explicit list when no ALL / PRIORITY / RETRY_GAP mode
# WIKIDATA_USER_AGENT="..."        # single UA when WIKIDATA_USER_AGENT_POOL is empty
# WIKIDATA_USER_AGENT_POOL="Mozilla/5.0 (Windows NT 10.0; Win64; x64) ... Chrome/120...###Mozilla/5.0 (Macintosh; Intel Mac OS X 10_15_7) ...###Mozilla/5.0 (Linux; Android 14; ...) ... Mobile Safari/537.36"
#   Separate multiple UAs with ### (not comma — commas appear inside each UA string). Rotates per WDQS request.
# WIKIDATA_LOG_UA_STATS=1            # defaults ON when USER_AGENT_POOL is set; WDQS summaries in logs (ok vs 429 vs transport)
# WIKIDATA_UA_STATS_LOG_EVERY_NET=10  # emit summary every N completed WDQS calls (HTTP 200)
# WIKIDATA_HTTP_KEEPALIVE=1          # optional; default off — avoids RemoteProtocolError after long throttles/VPN

